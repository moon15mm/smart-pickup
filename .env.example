# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=smartpickup
POSTGRES_PASSWORD=secret
POSTGRES_DB=smartpickup
DATABASE_URL=postgresql://smartpickup:secret@localhost:5432/smartpickup

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redissecret@localhost:6379
REDIS_PASSWORD=redissecret

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3002

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+966xxxxxxxxx

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────────────
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email (SendGrid) ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxx
SENDGRID_FROM=noreply@smartpickup.sa

# ── Firebase (Push Notifications) ────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# ── Payments (Checkout.com) ───────────────────────────────────────────────────
CHECKOUT_SECRET_KEY=sk_sbox_xxxxxxxxxxxx
CHECKOUT_PUBLIC_KEY=pk_sbox_xxxxxxxxxxxx
CHECKOUT_WEBHOOK_SECRET=your_webhook_secret

# ── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxx
AWS_REGION=me-south-1
AWS_S3_BUCKET=smart-pickup-media

# ── AI (OpenAI / AWS Bedrock) ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxx
