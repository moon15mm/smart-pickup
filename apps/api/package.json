{
  "name": "@smart-pickup/api",
  "version": "1.0.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "node_modules/.bin/nest build || npx @nestjs/cli build",
    "start": "node dist/main",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "migration:generate": "typeorm migration:generate -d dist/database/data-source.js",
    "migration:run": "typeorm migration:run -d dist/database/data-source.js",
    "migration:revert": "typeorm migration:revert -d dist/database/data-source.js",
    "seed:run": "ts-node src/database/seeds/index.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/mapped-types": "^2.0.5",
    "typescript": "^5.4.0",
    "ts-node": "^10.9.2",
    "@nestjs/websockets": "^10.3.0",
    "@smart-pickup/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "openai": "^4.47.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "socket.io": "^4.7.5",
    "twilio": "^5.1.0",
    "typeorm": "^0.3.20",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.12.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
