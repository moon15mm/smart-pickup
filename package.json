{
  "name": "smart-pickup",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": "20.x",
    "pnpm": "9.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:api": "pnpm --filter @smart-pickup/api dev",
    "dev:web": "pnpm --filter @smart-pickup/web dev",
    "dev:dashboard": "pnpm --filter @smart-pickup/dashboard dev",
    "build": "pnpm --parallel -r build",
    "test": "pnpm --parallel -r test",
    "lint": "pnpm --parallel -r lint",
    "db:migrate": "pnpm --filter @smart-pickup/api migration:run",
    "db:seed": "pnpm --filter @smart-pickup/api seed:run"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
